# pgkg environment variables
# Copy this file to .env and fill in the values.

DATABASE_URL=postgresql://user:password@localhost:5432/pgkg

# LLM provider: openai | anthropic | ollama
PGKG_LLM_PROVIDER=openai
PGKG_LLM_MODEL=gpt-4o-mini-2024-07-18

# Optional: override model used only for proposition extraction.
# When unset, PGKG_LLM_MODEL is used for extraction.
# PGKG_EXTRACTOR_MODEL=gpt-4o-mini-2024-07-18

# Judge model for benchmark evaluation (pinned for reproducibility).
PGKG_JUDGE_MODEL=gpt-4o-2024-08-06
PGKG_JUDGE_PROVIDER=openai

# OpenAI API key (required when PGKG_LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...

# Optional: override OpenAI base URL (OpenRouter, Groq, etc.)
# OpenRouter example: PGKG_OPENAI_BASE_URL=https://openrouter.ai/api/v1
# Groq example:       PGKG_OPENAI_BASE_URL=https://api.groq.com/openai/v1
# PGKG_OPENAI_BASE_URL=

# Anthropic API key (required when PGKG_LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...

# Embedding and reranking models (open-source, run in-process)
PGKG_EMBED_MODEL=BAAI/bge-m3
PGKG_RERANK_MODEL=BAAI/bge-reranker-v2-m3
PGKG_EMBED_DIM=1024

# Set to 1 to skip LLM calls in tests (uses dummy extraction)
# PGKG_OFFLINE_EXTRACT=1
