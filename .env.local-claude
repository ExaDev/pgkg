# Local experimentation only — uses Claude Pro/Max subscription via the
# local `claude` CLI (claude-agent-sdk). NOT suitable for benchmark runs
# (rate limits + ToS). For benchmarks, use .env.bench-mem0-stack.

PGKG_DATABASE_URL=postgresql://pgkg:pgkg@localhost:5432/pgkg
PGKG_EXTRACT_PROPOSITIONS=1
PGKG_LLM_PROVIDER=claude_code
PGKG_LLM_MODEL=claude-haiku-4-5-20251001
PGKG_EXTRACTOR_MODEL=claude-haiku-4-5-20251001
PGKG_JUDGE_MODEL=claude-haiku-4-5-20251001
PGKG_EMBED_MODEL=BAAI/bge-m3
PGKG_RERANK_MODEL=BAAI/bge-reranker-v2-m3
