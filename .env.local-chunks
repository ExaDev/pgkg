# Zero-LLM local mode: pure chunks-only ingest, hybrid retrieval +
# rerank + MMR + recency. No proposition extraction, no API key, no
# claude CLI. Closest in spirit to mempalace / vanilla RAG, but with
# pgkg's hybrid retrieval pipeline on top.
#
# Use this when you just want to play with the system on local data
# without spending tokens or configuring a provider.

PGKG_EXTRACT_PROPOSITIONS=0
PGKG_DATABASE_URL=postgresql://pgkg:pgkg@localhost:5432/pgkg
PGKG_EMBED_MODEL=BAAI/bge-m3
PGKG_RERANK_MODEL=BAAI/bge-reranker-v2-m3
